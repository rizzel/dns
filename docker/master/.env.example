# MariaDB
MARIADB_DATABASE=pdns
MARIADB_USER=pdns_user
MARIADB_PASSWORD=changeme

# Replication
REPL_PASSWORD=changeme_repl

# DNS
DNS_PORT=53

# WireGuard
WG_PORT=51820

# PHP / HAProxy
HTTP_PORT=8080

# Initial admin user (optional - defaults shown)
DNS_ADMIN_USER=admin
DNS_ADMIN_EMAIL=admin@localhost

# Mail (optional - defaults to dns@<hostname> if empty)
MAIL_FROM=
USE_PEAR_MAIL=false
PEAR_BACKEND=
PEAR_HOST=
PEAR_USERNAME=
PEAR_PASSWORD=
PEAR_AUTH=LOGIN
PEAR_PORT=25